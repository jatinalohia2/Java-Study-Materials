package multithreading;

class MyThread extends Thread {
	
	public MyThread() {
	}
	
	public MyThread(String name) {
		super(name);
	}

	@Override
	public void run() {


			try {
				Thread.sleep(2000); // waiting state :
			} catch (InterruptedException e) {
				e.printStackTrace();
			}
			System.out.println("Thread starts " + Thread.currentThread().getName());
		}
	
}

public class Dummy {

	public static void main(String[] args) {

		MyThread myThread = new MyThread("T1");
		myThread.start();

		MyThread myThread2 = new MyThread("T2");
		myThread2.start();

		MyThread myThread3 = new MyThread("T3");
		myThread3.start();
		
		System.out.println(myThread.getPriority());
		System.out.println(myThread2.getPriority());
		System.out.println(myThread3.getPriority());
		
	}
}
