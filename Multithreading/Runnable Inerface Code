package multithreading;

// 2 Runnable interface :

class RunThread extends Dog implements Runnable {

	@Override
	public void run() {

		for (int i = 0; i < 5; i++) {

			try {
				Thread.sleep(2000);
			} catch (InterruptedException e) {
				e.printStackTrace();
			}
			System.out.println("Thread starts : "+Thread.currentThread().getName());
		}

	}

}

public class Testing {

	public static void main(String[] args) {

		RunThread runThread = new RunThread();

		Thread thread = new Thread(runThread , "t1");
		thread.start();

		Thread thread1 = new Thread(runThread , "t2");
		thread1.start();

		Thread thread2 = new Thread(runThread , "t3");
		thread2.start();
	}
}
