/* =========================================================
   20. AGGREGATE FUNCTIONS
=========================================================*/

-- Count
SELECT COUNT(*) AS total_count
FROM customer
WHERE gender = 'male';

-- Max & Min
SELECT MAX(sal) AS maximum_salary,
       MIN(sal) AS minimum_salary
FROM customer;

-- Average
SELECT AVG(sal) AS average_salary
FROM customer;



/* =========================================================
   21. GROUP BY
=========================================================*/

SELECT gender AS gen,
       SUM(sal) AS total_salary
FROM customer
GROUP BY gender;



/* =========================================================
   22. STRING FUNCTIONS
=========================================================*/

SELECT email,
       LENGTH(gender) AS total_len
FROM customer;

SELECT CONCAT(gender,'(',age,')') AS info
FROM customer;



/* =========================================================
   23. DATE FUNCTIONS
=========================================================*/

-- Current date & time
SELECT NOW();

-- Month name from date
SELECT email,
       MONTHNAME(dob) AS birth_month
FROM customer;

-- Days lived
SELECT email,
       DATEDIFF(CURDATE(), dob) AS days_lived
FROM customer;
