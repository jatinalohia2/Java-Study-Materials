/* =========================================================
   1. DATABASE CREATION
=========================================================*/

-- Create a new database
CREATE DATABASE mysqldb;

-- Select database to work with
USE mysqldb;



/* =========================================================
   2. TABLE CREATION : EMPLOYEE
=========================================================*/

-- Create employee table demonstrating different data types
CREATE TABLE employee (
    id INT,                                   -- Employee ID
    first_name VARCHAR(100),                  -- Employee Name
    age INT,                                  -- Employee Age
    gender ENUM('male','female','other'),     -- Fixed allowed values
    dob DATE,                                 -- Date of Birth
    created_by TIMESTAMP DEFAULT CURRENT_TIMESTAMP, -- Auto timestamp
    active_emp BOOLEAN,                       -- TRUE / FALSE value
    salary DECIMAL(5,2)                       -- Max 999.99
);



/* =========================================================
   3. DECIMAL DATATYPE EXAMPLE
=========================================================*/

-- Table to understand precision & scale
CREATE TABLE emp1 (
    sal DECIMAL(8,3)   -- 8 total digits, 3 after decimal
);

-- Insert sample value
