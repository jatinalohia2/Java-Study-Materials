/* =========================================================
   4. SELECT STATEMENTS
=========================================================*/

-- Fetch selected columns
SELECT id, first_name FROM employee;

-- Fetch all columns
SELECT * FROM employee;



/* =========================================================
   5. INSERT DATA (WRONG WAY)
=========================================================*/

