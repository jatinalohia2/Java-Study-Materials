/* =========================================================
   1. DATABASE CREATION
=========================================================*/

-- Create a new database
CREATE DATABASE mysqldb;

-- Select database to work with
USE mysqldb;



/* =========================================================
   2. TABLE CREATION : EMPLOYEE
=========================================================*/

-- Create employee table demonstrating different data types
CREATE TABLE employee (
    id INT,                                   -- Employee ID
    first_name VARCHAR(100),                  -- Employee Name
    age INT,                                  -- Employee Age
    gender ENUM('male','female','other'),     -- Fixed allowed values
    dob DATE,                                 -- Date of Birth
    created_by TIMESTAMP DEFAULT CURRENT_TIMESTAMP, -- Auto timestamp
    active_emp BOOLEAN,                       -- TRUE / FALSE value
    salary DECIMAL(5,2)                       -- Max 999.99
);



/* =========================================================
   3. DECIMAL DATATYPE EXAMPLE
=========================================================*/

-- Table to understand precision & scale
CREATE TABLE emp1 (
    sal DECIMAL(8,3)   -- 8 total digits, 3 after decimal
);

-- Insert sample value
INSERT INTO emp1(sal)
VALUES (123456.09);



/* =========================================================
   4. SELECT STATEMENTS
=========================================================*/

-- Fetch selected columns
SELECT id, first_name FROM employee;

-- Fetch all columns
SELECT * FROM employee;



/* =========================================================
   5. INSERT DATA (WRONG WAY)
=========================================================*/

-- ❌ ERROR:
-- Column count does not match table columns
INSERT INTO employee
VALUES (1, 'jatin', 12);



/* =========================================================
   6. INSERT DATA (CORRECT WAY)
=========================================================*/

-- ✅ Best Practice: Always specify column names
INSERT INTO employee
(id, first_name, age, gender, active_emp, dob, salary)
VALUES
(1, 'akshita', 12, 'female', TRUE, '2001-12-10', 50.01);



/* =========================================================
   7. DROP OPERATIONS
=========================================================*/

-- Delete table structure + data
DROP TABLE employee;

-- Delete entire database
DROP DATABASE mysqldb;



/* =========================================================
   8. TABLE RENAME
=========================================================*/

-- Rename table
RENAME TABLE emp TO customer;



/* =========================================================
   9. ALTER TABLE OPERATIONS
=========================================================*/

-- Add new column
ALTER TABLE customer ADD COLUMN age INT;

-- Drop and add column together
ALTER TABLE customer
DROP COLUMN id,
ADD COLUMN sal2 INT;

-- Modify datatype
ALTER TABLE customer MODIFY COLUMN sal VARCHAR(50);

-- Change column position
ALTER TABLE employee MODIFY COLUMN gender VARCHAR(50) FIRST;

ALTER TABLE employee MODIFY COLUMN age INT AFTER id;



/* =========================================================
   10. CREATE CUSTOMER TABLE (FINAL VERSION)
=========================================================*/

CREATE TABLE customer(
    id INT PRIMARY KEY AUTO_INCREMENT,
    age INT NOT NULL,
    sal INT DEFAULT 1,
    email VARCHAR(30) UNIQUE
);

SELECT * FROM customer;



/* =========================================================
   11. INSERT DATA
=========================================================*/

INSERT INTO customer(age, email, sal)
VALUES (15, NULL, 100);



/* =========================================================
   12. DELETE OPERATIONS
=========================================================*/

-- Delete specific row
DELETE FROM customer WHERE id = 2;

SELECT * FROM customer;



/* =========================================================
   13. WHERE CONDITIONS
=========================================================*/

-- Not equal condition
SELECT * FROM customer WHERE sal <> 300;

-- NULL checking
SELECT * FROM customer WHERE email IS NULL;
SELECT * FROM customer WHERE email IS NOT NULL;



/* =========================================================
   14. FILTERING DATA
=========================================================*/

SELECT * FROM employee
WHERE gender NOT IN ('male','female');

-- LIKE operator
SELECT * FROM employee WHERE first_name LIKE 'a%';
SELECT * FROM employee WHERE first_name LIKE 'a%a';



/* =========================================================
   15. ORDER BY & LIMIT
=========================================================*/

SELECT * FROM customer ORDER BY age ASC;

SELECT * FROM customer
WHERE age < 15
ORDER BY id DESC
LIMIT 2;

-- Pagination example
SELECT * FROM customer LIMIT 2,2;



/* =========================================================
   16. UPDATE & DELETE
=========================================================*/

UPDATE customer
SET age = 30, sal = 3000
WHERE id > 3;

DELETE FROM customer WHERE id = 1;


/*
DROP   → deletes structure + data
DELETE → deletes selected rows
TRUNCATE → deletes all rows only
*/



/* =========================================================
   17. ADD NEW COLUMN
=========================================================*/

ALTER TABLE customer
ADD COLUMN gender ENUM('male','female');

SELECT * FROM customer;



/* =========================================================
   18. CONSTRAINTS
=========================================================*/

-- Unique constraint
ALTER TABLE customer ADD CONSTRAINT unique_age UNIQUE(age);

-- Check constraint
ALTER TABLE customer
ADD CONSTRAINT customer_chk
CHECK(dob > '2001-10-06');

-- Drop constraint
ALTER TABLE customer DROP CONSTRAINT customer_chk;



