package com.techtamasha.techtamasha;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.techtamasha.techtamasha.entity.Student;
import com.techtamasha.techtamasha.repository.StudentRepository;

/*
 * @Component
 * Marks this class as a Spring Bean.
 * Spring automatically creates object of this class
 * and manages its lifecycle (IOC Container).
 *
 * NOTE:
 * Normally controllers use @Controller or @RestController.
 * Here @Component is used just for testing/business logic.
 */
@Component
public class StudentController {

    /*
     * @Autowired
     * Dependency Injection.
     * Spring automatically injects StudentRepository object.
     * No need to create object manually using new keyword.
     */
    @Autowired
    StudentRepository studentRepository;

    /*
     * Method to save and delete student data
     */
    public void saveStudent() {

        /*
         * Creating Student object.
         * id = null → database will auto-generate ID
         */
        Student student = new Student(null, "jatin", "bca", 12, 90, "hello", "hii");

        /*
         * save()
         * Inserts record into database.
         * If ID exists → update
         * If ID is null → insert
         */
        studentRepository.save(student); // INSERT into table


        /*
         * Creating another student object
         * Here id = 1 means record with ID 1.
         */
        Student student1 = new Student(1, "jatin", "bca", 12, 90, "hello", "hii");

        /*
         * delete()
         * Deletes matching entity from database.
         * Usually we delete using ID (better practice).
         */
        studentRepository.delete(student1);
    }
}

