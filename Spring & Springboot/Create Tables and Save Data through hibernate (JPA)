package com.techtamasha.techtamasha;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.CommandLineRunner;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;

/*
 * @SpringBootApplication
 *
 * This is the MAIN class of Spring Boot.
 * It is the starting point of the application.
 *
 * It is a combination of:
 * 1. @Configuration  → Java configuration class
 * 2. @EnableAutoConfiguration → Auto setup by Spring Boot
 * 3. @ComponentScan → Scans all components automatically
 */
@SpringBootApplication

/*
 * CommandLineRunner
 *
 * Interface used to run code AFTER
 * Spring Boot application starts successfully.
 *
 * Useful for:
 * - Testing database
 * - Initial data insert
 * - Running startup logic
 */
public class TechtamashaApplication implements CommandLineRunner {

    /*
     * Injecting StudentController bean using Dependency Injection
     * Spring automatically provides object.
     */
    @Autowired
    StudentController studentController;


    /*
     * main() method
     * Entry point of Java application.
     * Starts Spring Boot server and IOC container.
     */
    public static void main(String[] args) {
        SpringApplication.run(TechtamashaApplication.class, args);
    }


    /*
     * run() method executes automatically
     * after application startup.
     */
    @Override
    public void run(String... args) throws Exception {

        // Calling method to save & delete student
        studentController.saveStudent();
    }
}
