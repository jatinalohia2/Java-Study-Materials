package com.techtamasha.techtamasha.entity;

// JPA annotations used for database mapping
import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.Table;

/*
 * @Entity
 * Marks this class as a JPA Entity.
 * It means this class will be mapped to a database table.
 */
@Entity

/*
 * @Table
 * Specifies the table name in the database.
 * If not given, table name = class name (Student).
 */
@Table(name = "pisoft_student")
public class Student {

    /*
     * @Id
     * Marks this field as PRIMARY KEY of the table.
     */
    @Id

    /*
     * @GeneratedValue
     * Automatically generates ID values.
     * GenerationType.AUTO lets JPA decide strategy.
     */
    @GeneratedValue(strategy = GenerationType.AUTO)
    private Integer id; // Primary Key


    /*
     * Default Constructor
     * Required by JPA/Hibernate to create objects using reflection.
     */
    public Student() {}


    /*
     * @Column
     * Used to customize column properties in database.
     *
     * name = "student_name"  → column name in DB
     * nullable = false       → cannot store NULL value
     * updatable = false      → value cannot be updated after insert
     * unique = true          → duplicate values not allowed
     * length = 10            → max character length = 10
     */
    @Column(
        name = "student_name",
        nullable = false,
        updatable = false,
        unique = true,
        length = 10
    )
    private String name;

    // Course name of the student
    private String course;

    // Student age
    private Integer age;

    // Phone number (Integer used here, but Long/String is better in real apps)
    private Integer phn;

    // Father's name
    private String fatherName;

    // Mother's name
    private String motherName;


    /*
     * Parameterized Constructor
     * Used to create object with values.
     */
    public Student(Integer id, String name, String course, Integer age,
                   Integer phn, String fatherName, String motherName) {
        super();
        this.id = id;
        this.name = name;
        this.course = course;
        this.age = age;
        this.phn = phn;
        this.fatherName = fatherName;
        this.motherName = motherName;
    }

}

